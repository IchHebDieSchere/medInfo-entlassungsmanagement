{
  "name": "med-info-fhir",
  "version": "1.0.0",
  "description": "API-Grundgerüst für das MedInfo-Entlassungsmanagement",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "src/service.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/service.js",
    "start:dev": "nodemon --watch src --exec \"node --env-file-if-exists=.env\" src/service.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test test/app.test.js test/auth.test.js test/http-server.test.js test/fhir-client.unit.test.js",
    "test:integration": "node --env-file-if-exists=.env.test --test --test-concurrency=1 test/integration/patient.integration.test.js test/integration/discharge-audit.integration.test.js test/integration/discharge-workflow.integration.test.js test/integration/discharge-service.integration.test.js",
    "check": "npm run lint && npm run format:check && npm test",
    "mongodb": "docker run --rm -v ./database:/data/db -p 27017:27017 mongo:8",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "fhir": "docker compose -f docker-compose.fhir.yml up -d",
    "fhir:down": "docker compose -f docker-compose.fhir.yml down",
    "fhir:test": "node --test test/app.test.js test/auth.test.js test/http-server.test.js test/fhir-client.unit.test.js",
    "demo:discharge": "node --env-file-if-exists=.env scripts/discharge-flow-demo.js",
    "demo:patient": "node --env-file-if-exists=.env scripts/patient-lifecycle-demo.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kochd-htw/med-info-fhir.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kochd-htw/med-info-fhir/issues"
  },
  "homepage": "https://github.com/kochd-htw/med-info-fhir#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5"
  }
}
